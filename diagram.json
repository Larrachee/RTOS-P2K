{
  "version": 1,
  "author": "Single Lift Control System FreeRTOS with LCD",
  "editor": "wokwi",
  "parts": [
    { "type": "wokwi-esp32-devkit-v1", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    
    { "type": "wokwi-pushbutton", "id": "btn1", "top": -80, "left": -350, "attrs": { "color": "blue", "label": "Floor 1" } },
    { "type": "wokwi-pushbutton", "id": "btn2", "top": -40, "left": -350, "attrs": { "color": "blue", "label": "Floor 2" } },
    { "type": "wokwi-pushbutton", "id": "btn3", "top": 0, "left": -350, "attrs": { "color": "blue", "label": "Floor 3" } },
    { "type": "wokwi-pushbutton", "id": "btn4", "top": 40, "left": -350, "attrs": { "color": "blue", "label": "Floor 4" } },
    { "type": "wokwi-pushbutton", "id": "btn5", "top": 80, "left": -350, "attrs": { "color": "blue", "label": "Floor 5" } },
    { "type": "wokwi-pushbutton", "id": "btnEmg", "top": 120, "left": -350, "attrs": { "color": "red", "label": "EMERGENCY" } },
    { "type": "wokwi-pushbutton", "id": "btnOpen", "top": 160, "left": -350, "attrs": { "color": "green", "label": "OPEN" } },
    { "type": "wokwi-pushbutton", "id": "btnClose", "top": 200, "left": -350, "attrs": { "color": "yellow", "label": "CLOSE" } },
    
    { "type": "wokwi-lcd1602", "id": "lcd", "top": 250, "left": 200, "attrs": { "pins": "i2c" } }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    
    [ "btn1:1.r", "esp:D13", "blue", [ "h0" ] ],
    [ "btn1:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btn2:1.r", "esp:D12", "blue", [ "h0" ] ],
    [ "btn2:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btn3:1.r", "esp:D14", "blue", [ "h0" ] ],
    [ "btn3:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btn4:1.r", "esp:D27", "blue", [ "h0" ] ],
    [ "btn4:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btn5:1.r", "esp:D26", "blue", [ "h0" ] ],
    [ "btn5:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btnEmg:1.r", "esp:D25", "red", [ "h0" ] ],
    [ "btnEmg:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btnOpen:1.r", "esp:D33", "green", [ "h0" ] ],
    [ "btnOpen:2.r", "esp:GND.1", "black", [ "h0" ] ],
    [ "btnClose:1.r", "esp:D32", "yellow", [ "h0" ] ],
    [ "btnClose:2.r", "esp:GND.1", "black", [ "h0" ] ],
    
    [ "lcd:GND", "esp:GND.1", "black", [ "h0" ] ],
    [ "lcd:VCC", "esp:3V3", "red", [ "h0" ] ],
    [ "lcd:SDA", "esp:D21", "green", [ "h0" ] ],
    [ "lcd:SCL", "esp:D22", "blue", [ "h0" ] ]
  ],
  "dependencies": {}
